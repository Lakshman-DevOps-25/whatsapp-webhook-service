# ========================= App =========================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ========================= MongoDB =====================
# e.g. mongodb+srv://user:pass@cluster/db  or  mongodb://localhost:27017/whatsapp
# MONGO_URI=mongodb://localhost:27017/whatsapp_service
MONGO_URI=mongodb+srv://lakshmana-gundala:Mongodb123@cluster0.mpkvh0j.mongodb.net/whatsapp_capture

# ===================== WhatsApp Cloud API ==============
# Graph API base + version
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v19.0
# Phone number + WABA identifiers (from Meta App dashboard)
WHATSAPP_PHONE_NUMBER_ID=1277264628801939
WHATSAPP_BUSINESS_ACCOUNT_ID=996991492830362
WHATSAPP_DISPLAY_NAME=My WhatsApp Number
# App credentials (used for webhook signature verification + token exchange)
WHATSAPP_APP_ID=1477689156878683
WHATSAPP_APP_SECRET=a288addd53f4f3e19d9369cdb4990e80
# Initial long-lived access token (will be persisted to Mongo and auto-managed)
WHATSAPP_ACCESS_TOKEN=EAAUZC81FIwVsBR3W26zpSWYfegsaKe3o2v69ZBYUlh7A8VZCshU2GVwqef7xuYbxVmKNhaMbZBKnWfZCqBcZA46mBoJODpmAn3cSvGqnahBDZC2iyJ2pTAT4vNJ5KtZCwOAxvFAdZBvSjZB4EXVc4mZA67NufB8dTs98NZAoyRfBBVA5Yhu7bzLkmljQR4mZBfe15r8aju6orTpwQ87fVOLpr9lrWZB2oh44VOa7tht6ZAiZBxFiQRTpkayHH5tx5ZBDeeyoBkVDpBrYNNl50ZCIhiKd9vMVZCc
# Token you set in the Meta webhook configuration screen (GET verification)
WHATSAPP_VERIFY_TOKEN=whatsap-webhook

# ===================== Token lifecycle =================
TOKEN_TTL_DAYS=60
TOKEN_REFRESH_THRESHOLD_DAYS=50
# Background check cadence (hours). 0 disables the periodic check.
TOKEN_CHECK_INTERVAL_HOURS=24

# ===================== MinIO ===========================
# NOTE: the MinIO *console* for the public sandbox is https://play.min.io:9443,
# but the SDK needs the *S3 API* endpoint. For the public playground that is
# play.min.io over TLS. Override all of these for your own MinIO.
MINIO_ENDPOINT=play.min.io
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=whatsapp-media
MINIO_INBOUND_PREFIX=inbound
MINIO_OUTBOUND_PREFIX=outbound
# Presigned URL lifetime (seconds) for stored media; default 7 days
MINIO_PRESIGN_EXPIRY_SECONDS=604800
